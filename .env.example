# Copy to .env and fill in. .env is gitignored - secrets live there, never in code.

# LM Studio API key (LM Studio enforces key auth; find/set it in LM Studio's
# Developer/server settings). Every component uses this to talk to :1234.
OPENAI_API_KEY=sk-lm-CHANGE-ME

# LM Studio scheduler proxy. LiteLLM uses this for chat/code aliases that should
# wake a profile on first request instead of relying on LM Studio JIT loads.
LMSTUDIO_SCHEDULER_PORT=1235
LMSTUDIO_SCHEDULER_HOST=0.0.0.0
LMSTUDIO_SCHEDULER_IDLE_SECONDS=5400

# This box's LAN IP - the ONE place it lives. Containers use it to reach LM Studio
# on the host (host.docker.internal doesn't route under WSL NAT); expose-services.ps1
# binds portproxies to it. If the IP changes: update here, `docker compose up -d`,
# re-run `stack expose`.
# Find it:  (Get-NetIPConfiguration | ? { $_.IPv4DefaultGateway }).IPv4Address.IPAddress
HOST_LAN_IP=YOUR-LAN-IP

# WSL distro that hosts docker-ce (stackctl + scripts read this).
WSL_DISTRO=Ubuntu-24.04

# --- vLLM (optional, compose profile "vllm") ---
# Pick an AWQ/GPTQ 4-bit quant that fits one GPU's VRAM; auto-downloads to hf-cache.
VLLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
VLLM_GPU_MEM_UTIL=0.28
VLLM_MAX_MODEL_LEN=4096
# HF_TOKEN=hf_...                     # only for gated HuggingFace models

# --- Kimi-K2.7-Code (optional, on-demand host model) ---
# Kimi idles as a tiny wake proxy on :8095. The real llama.cpp backend starts on
# first request and listens on :8096. That first request returns a warming error;
# retry after the model finishes loading into RAM.
# These paths point outside the repo (binary + GGUF); stackctl defaults to the values below,
# so only set them if your install differs. KIMI_CPU_RANGE forces threads across BOTH sockets
# (Windows otherwise confines them to one processor group = one socket); set it to "" on a
# single-socket box. ctx kept small by default.
# KIMI_SERVER=C:\Users\<you>\llamacpp\llama-server.exe
# KIMI_MODEL=C:\Users\<you>\models\Kimi-K2.7-Code-GGUF\UD-Q2_K_XL\Kimi-K2.7-Code-UD-Q2_K_XL-00001-of-00008.gguf
# KIMI_THREADS=192
# KIMI_CPU_RANGE=0-191
# KIMI_CTX=8192
# KIMI_PROXY_PORT=8095
# KIMI_BACKEND_PORT=8096
# KIMI_IDLE_TIMEOUT_SECONDS=5400
# KIMI_PROXY_BASE_URL=http://${HOST_LAN_IP}:8095/v1

# Bearer token clients must present to the Mem0 memory service (:8077).
# Generate:  python -c "import secrets; print('msk_' + secrets.token_hex(32))"
MEMORI_SERVICE_TOKEN=msk_CHANGE-ME

# Meshtastic-only memory for Hermes. This runs as a separate Mem0 collection
# and exposes a narrow MCP bridge for Hermes to recall/record Meshtastic facts.
# Generate token: python -c "import secrets; print('msk_mesh_' + secrets.token_hex(32))"
MESHTASTIC_MEM0_SERVICE_TOKEN=msk_mesh_CHANGE-ME
MESHTASTIC_MEM0_PORT=8078
MESHTASTIC_MCP_PORT=8079
MESHTASTIC_MEM0_COLLECTION=mem0_meshtastic
MESHTASTIC_MEMORY_USER_ID=hermes:meshtastic

# LiteLLM gateway master key (admin key for :4000; do not hand this to apps).
# Generate:  python -c "import secrets; print('sk-' + secrets.token_hex(24))"
LITELLM_MASTER_KEY=sk-CHANGE-ME

# LiteLLM Postgres (litellm-db): enables virtual keys, spend tracking, and the admin UI at :4000/ui.
# DB password + salt key (salt encrypts secrets in the DB; never change it after first use) and
# the admin-UI login. Generate each:  python -c "import secrets; print(secrets.token_hex(16))"
LITELLM_DB_PASSWORD=CHANGE-ME
LITELLM_SALT_KEY=sk-salt-CHANGE-ME
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=CHANGE-ME

# LiteLLM per-app virtual keys. Generate these after LiteLLM + litellm-db are up.
# They are for per-app tracking. Do not set model lists, spend caps, or rate limits unless you want access control.
# The app still requests its tracking alias: hermes, cline, qwen-code, claude-local-*, brain/embed.
LITELLM_KEY_OPENWEBUI=sk-CHANGE-ME
LITELLM_KEY_MEM0=sk-CHANGE-ME
LITELLM_KEY_HERMES=sk-CHANGE-ME
LITELLM_KEY_CLINE=sk-CHANGE-ME
LITELLM_KEY_QWEN=sk-CHANGE-ME
LITELLM_KEY_CLAUDE=sk-CHANGE-ME

# Token for the Jupyter code-interpreter sandbox (OpenWebUI uses it internally).
JUPYTER_TOKEN=CHANGE-ME

# MinerU basic auth - what you type at the browser prompt on :7860/:8000.
# The Caddy proxy checks a BCRYPT HASH of this password in mineru/Caddyfile:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'YOUR-PASSWORD'
# Put the output hash in mineru/Caddyfile next to the username.
MINERU_AUTH_USER=admin
MINERU_AUTH_PASS=CHANGE-ME

# stackctl web dashboard (host FastAPI on :8090). Leave WEB_AUTH_PASS blank for
# localhost-only with no auth. To reach it from the LAN: set a password AND
# WEB_BIND=0.0.0.0, then open the firewall for 8090 (scripts/expose-web.ps1).
# Basic auth is sent over plain HTTP, so only do this on a trusted LAN.
WEB_AUTH_USER=admin
WEB_AUTH_PASS=
WEB_BIND=127.0.0.1

# LLM token usage -> your external InfluxDB (v2). Leave blank to disable metering.
# Grafana then reads these points (measurement llm_usage; tags user/model/status).
INFLUX_URL=http://your-influx-host:8086
INFLUX_ORG=your-org
INFLUX_BUCKET=llm_usage
INFLUX_TOKEN=your-write-token
INFLUX_MEASUREMENT=llm_usage

# Shared secret so the LiteLLM usage callback can post token data to the dashboard's
# local store (the dashboard's 'token usage' card). Generate: python -c "import secrets;print(secrets.token_hex(16))"
USAGE_INGEST_TOKEN=CHANGE-ME
